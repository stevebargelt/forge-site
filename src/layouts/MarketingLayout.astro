---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Forge — AI-native multi-agent orchestration for engineering teams.' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} — Forge</title>
    <script>document.documentElement.classList.add('js')</script>
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <header class="site-header">
      <nav class="site-nav" aria-label="Main navigation">
        <a href="/" class="nav-wordmark" aria-label="Forge home">
          <svg class="nav-logo" width="28" height="28" viewBox="0 0 28 28" fill="none" aria-hidden="true">
            <rect width="28" height="28" rx="6" fill="var(--forge-color-accent)"/>
            <path d="M7 8h14M7 14h10M7 20h7" stroke="var(--forge-color-text-on-accent)" stroke-width="2.5" stroke-linecap="round"/>
          </svg>
          <span class="nav-wordmark-text">Forge</span>
        </a>
        <ul class="nav-links" role="list">
          <li><a href="/what-forge-does" class="nav-link">What Forge does</a></li>
          <li><a href="/how-forge-runs-work" class="nav-link">How it works</a></li>
          <li><a href="/how-routing-works" class="nav-link">Routing</a></li>
          <li class="nav-guides-item">
            <button
              class="nav-link nav-guides-btn"
              type="button"
              aria-expanded="false"
              aria-controls="guides-menu"
            >
              Guides
              <svg class="nav-caret" width="10" height="10" viewBox="0 0 10 10" aria-hidden="true" fill="none">
                <path d="M2 3.5l3 3 3-3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
            <ul id="guides-menu" class="nav-guides-menu" role="list">
              <li><a href="/add-a-feature" class="nav-guides-link">Add a feature</a></li>
              <li><a href="/do-research" class="nav-guides-link">Do research</a></li>
              <li><a href="/kick-off-a-project" class="nav-guides-link">New project</a></li>
            </ul>
          </li>
          <li><a href="/docs/" class="nav-link">Docs</a></li>
        </ul>
        <button class="nav-toggle" aria-expanded="false" aria-controls="mobile-nav" aria-label="Toggle navigation" type="button">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <path d="M3 5h14M3 10h14M3 15h14" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          </svg>
        </button>
      </nav>
    </header>

    <nav id="mobile-nav" class="nav-mobile" aria-label="Mobile navigation" aria-hidden="true">
      <ul class="nav-mobile-links" role="list">
        <li><a href="/what-forge-does" class="nav-mobile-link">What Forge does</a></li>
        <li><a href="/how-forge-runs-work" class="nav-mobile-link">How it works</a></li>
        <li><a href="/how-routing-works" class="nav-mobile-link">Routing</a></li>
        <li class="nav-mobile-section">
          <span class="nav-mobile-section-label">Guides</span>
          <ul class="nav-mobile-sublist" role="list">
            <li><a href="/add-a-feature" class="nav-mobile-link nav-mobile-link--sub">Add a feature</a></li>
            <li><a href="/do-research" class="nav-mobile-link nav-mobile-link--sub">Do research</a></li>
            <li><a href="/kick-off-a-project" class="nav-mobile-link nav-mobile-link--sub">New project</a></li>
          </ul>
        </li>
        <li><a href="/docs/" class="nav-mobile-link">Docs</a></li>
      </ul>
    </nav>

    <main id="main-content">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="footer-inner">
        <p class="footer-copy">
          &copy; {new Date().getFullYear()} Forge. Built for engineers.
        </p>
        <nav class="footer-links" aria-label="Footer navigation">
          <a href="/docs/" class="footer-link">Docs</a>
          <a href="/what-forge-does" class="footer-link">What Forge does</a>
          <a href="/how-forge-runs-work" class="footer-link">How it works</a>
          <a href="/how-routing-works" class="footer-link">Routing</a>
          <a href="/add-a-feature" class="footer-link">Add a feature</a>
          <a href="/do-research" class="footer-link">Do research</a>
          <a href="/kick-off-a-project" class="footer-link">New project</a>
        </nav>
      </div>
    </footer>

    <script>
      // Mobile nav toggle
      const toggle = document.querySelector('.nav-toggle');
      const panel = document.getElementById('mobile-nav');
      if (toggle && panel) {
        toggle.addEventListener('click', () => {
          const expanded = toggle.getAttribute('aria-expanded') === 'true';
          toggle.setAttribute('aria-expanded', String(!expanded));
          if (expanded) {
            panel.setAttribute('aria-hidden', 'true');
          } else {
            panel.removeAttribute('aria-hidden');
          }
          panel.classList.toggle('nav-mobile--open', !expanded);
        });

        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape' && toggle.getAttribute('aria-expanded') === 'true') {
            toggle.setAttribute('aria-expanded', 'false');
            panel.setAttribute('aria-hidden', 'true');
            panel.classList.remove('nav-mobile--open');
            toggle.focus();
          }
        });
      }

      // Guides dropdown
      const guidesBtn = document.querySelector('.nav-guides-btn');
      const guidesMenu = document.getElementById('guides-menu');

      if (guidesBtn && guidesMenu) {
        const guidesItem = guidesBtn.closest('.nav-guides-item');

        function openGuides() {
          guidesMenu.classList.add('nav-guides-menu--open');
          guidesBtn.setAttribute('aria-expanded', 'true');
        }

        function closeGuides(returnFocus) {
          guidesMenu.classList.remove('nav-guides-menu--open');
          guidesBtn.setAttribute('aria-expanded', 'false');
          if (returnFocus) guidesBtn.focus();
        }

        guidesBtn.addEventListener('click', () => {
          const isOpen = guidesBtn.getAttribute('aria-expanded') === 'true';
          if (isOpen) {
            closeGuides(false);
          } else {
            openGuides();
          }
        });

        guidesBtn.addEventListener('keydown', (e) => {
          if (e.key === 'ArrowDown') {
            e.preventDefault();
            openGuides();
            const first = guidesMenu.querySelector('a');
            if (first) first.focus();
          } else if (e.key === 'Escape' && guidesBtn.getAttribute('aria-expanded') === 'true') {
            closeGuides(false);
          }
        });

        guidesMenu.addEventListener('keydown', (e) => {
          const links = Array.from(guidesMenu.querySelectorAll('a'));
          const idx = links.indexOf(document.activeElement);
          if (e.key === 'Escape') {
            closeGuides(true);
          } else if (e.key === 'ArrowDown') {
            e.preventDefault();
            const next = links[(idx + 1) % links.length];
            if (next) next.focus();
          } else if (e.key === 'ArrowUp') {
            e.preventDefault();
            if (idx <= 0) {
              closeGuides(true);
            } else {
              links[idx - 1].focus();
            }
          }
        });

        // Close on click outside the guides group
        document.addEventListener('click', (e) => {
          if (guidesItem && !guidesItem.contains(e.target)) {
            if (guidesBtn.getAttribute('aria-expanded') === 'true') {
              closeGuides(false);
            }
          }
        });

        // Close when focus moves outside the guides group
        document.addEventListener('focusin', (e) => {
          if (guidesItem && !guidesItem.contains(e.target)) {
            if (guidesBtn.getAttribute('aria-expanded') === 'true') {
              closeGuides(false);
            }
          }
        });
      }
    </script>
  </body>
</html>

<style>
  .skip-link {
    position: absolute;
    left: -9999px;
    top: var(--forge-space-4);
    z-index: 9999;
    padding: var(--forge-space-2) var(--forge-space-4);
    background: var(--forge-color-accent);
    color: var(--forge-color-text-on-accent);
    border-radius: var(--forge-radius-md);
    font-size: var(--forge-font-size-sm);
    font-weight: 600;
    text-decoration: none;
    white-space: nowrap;
  }

  .skip-link:focus {
    left: var(--forge-space-4);
  }

  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: color-mix(in srgb, var(--forge-color-surface) 92%, transparent);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--forge-color-border);
  }

  .site-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: var(--forge-layout-max-width);
    margin: 0 auto;
    padding: 0 var(--forge-space-6);
    height: 60px;
    gap: var(--forge-space-8);
  }

  .nav-wordmark {
    display: flex;
    align-items: center;
    gap: var(--forge-space-2);
    text-decoration: none;
    color: var(--forge-color-text-strong);
    font-weight: 700;
    font-size: var(--forge-font-size-lg);
    letter-spacing: -0.02em;
    flex-shrink: 0;
  }

  .nav-wordmark:hover {
    color: var(--forge-color-accent);
  }

  .nav-logo {
    flex-shrink: 0;
  }

  .nav-wordmark-text {
    font-family: var(--forge-font-family-display);
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: var(--forge-space-1);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav-link {
    display: inline-block;
    padding: 6px var(--forge-space-3);
    color: var(--forge-color-text-muted);
    text-decoration: none;
    font-size: var(--forge-font-size-sm);
    font-weight: 500;
    border-radius: var(--forge-radius-md);
    transition: color 0.15s ease, background-color 0.15s ease;
  }

  .nav-link:hover {
    color: var(--forge-color-text-strong);
    background-color: var(--forge-color-surface-raised);
  }

  .nav-link:focus-visible {
    outline: 2px solid var(--forge-color-accent);
    outline-offset: 2px;
  }

  /* ── Guides dropdown ─────────────────────────────────────────────────── */

  .nav-guides-item {
    position: relative;
  }

  .nav-guides-btn {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    background: none;
    border: none;
    font-family: inherit;
    cursor: pointer;
    /* .nav-link handles padding, color, font-size, border-radius */
  }

  .nav-caret {
    transition: transform 0.15s ease;
    flex-shrink: 0;
  }

  .nav-guides-btn[aria-expanded="true"] .nav-caret {
    transform: rotate(180deg);
  }

  /* No-JS: render menu as an inline visible list */
  .nav-guides-menu {
    list-style: none;
    margin: var(--forge-space-1) 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--forge-space-1);
  }

  /* With JS: hidden dropdown positioned absolutely */
  html.js .nav-guides-menu {
    display: none;
    position: absolute;
    top: calc(100% + var(--forge-space-1));
    left: 0;
    background: var(--forge-color-surface);
    border: 1px solid var(--forge-color-border);
    border-radius: var(--forge-radius-md);
    padding: var(--forge-space-1);
    min-width: 160px;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.08);
    z-index: 200;
    flex-direction: column;
    gap: var(--forge-space-1);
  }

  html.js .nav-guides-menu--open {
    display: flex;
  }

  .nav-guides-link {
    display: block;
    padding: 6px var(--forge-space-3);
    color: var(--forge-color-text-muted);
    text-decoration: none;
    font-size: var(--forge-font-size-sm);
    font-weight: 500;
    border-radius: var(--forge-radius-md);
    white-space: nowrap;
    transition: color 0.15s ease, background-color 0.15s ease;
  }

  .nav-guides-link:hover {
    color: var(--forge-color-text-strong);
    background-color: var(--forge-color-surface-raised);
  }

  .nav-guides-link:focus-visible {
    outline: 2px solid var(--forge-color-accent);
    outline-offset: 2px;
  }

  /* ── Nav toggle (hamburger) ──────────────────────────────────────────── */

  .nav-toggle {
    display: none;
    align-items: center;
    justify-content: center;
    padding: var(--forge-space-2);
    background: none;
    border: none;
    cursor: pointer;
    color: var(--forge-color-text-muted);
    border-radius: var(--forge-radius-md);
  }

  .nav-toggle:hover {
    color: var(--forge-color-text-strong);
    background: var(--forge-color-surface-raised);
  }

  .nav-toggle:focus-visible {
    outline: 2px solid var(--forge-color-accent);
    outline-offset: 2px;
  }

  /* ── Mobile nav panel ────────────────────────────────────────────────── */

  .nav-mobile {
    display: none;
    border-bottom: 1px solid var(--forge-color-border);
    background: var(--forge-color-surface-raised);
  }

  .nav-mobile--open {
    display: block;
  }

  .nav-mobile-links {
    list-style: none;
    margin: 0;
    padding: var(--forge-space-3) var(--forge-space-6);
    display: flex;
    flex-direction: column;
    gap: var(--forge-space-1);
  }

  .nav-mobile-link {
    display: block;
    padding: var(--forge-space-2) var(--forge-space-3);
    color: var(--forge-color-text-muted);
    text-decoration: none;
    font-size: var(--forge-font-size-sm);
    font-weight: 500;
    border-radius: var(--forge-radius-md);
  }

  .nav-mobile-link:hover {
    color: var(--forge-color-text-strong);
    background: var(--forge-color-surface);
  }

  .nav-mobile-link:focus-visible {
    outline: 2px solid var(--forge-color-accent);
    outline-offset: 2px;
  }

  /* ── Mobile Guides section ───────────────────────────────────────────── */

  .nav-mobile-section {
    display: flex;
    flex-direction: column;
  }

  .nav-mobile-section-label {
    display: block;
    padding: var(--forge-space-2) var(--forge-space-3);
    color: var(--forge-color-text-muted);
    font-size: var(--forge-font-size-xs);
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .nav-mobile-sublist {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--forge-space-1);
  }

  .nav-mobile-link--sub {
    padding-left: var(--forge-space-6);
  }

  /* ── Footer ──────────────────────────────────────────────────────────── */

  main {
    min-height: calc(100svh - 60px - 80px);
  }

  .site-footer {
    border-top: 1px solid var(--forge-color-border);
    background: var(--forge-color-surface-sunken);
  }

  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: var(--forge-layout-max-width);
    margin: 0 auto;
    padding: var(--forge-space-5) var(--forge-space-6);
    gap: var(--forge-space-4);
    flex-wrap: wrap;
  }

  .footer-copy {
    margin: 0;
    font-size: var(--forge-font-size-sm);
    color: var(--forge-color-text-muted);
  }

  .footer-links {
    display: flex;
    gap: var(--forge-space-4);
    flex-wrap: wrap;
  }

  .footer-link {
    font-size: var(--forge-font-size-sm);
    color: var(--forge-color-text-muted);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .footer-link:hover {
    color: var(--forge-color-accent);
  }

  .footer-link:focus-visible {
    outline: 2px solid var(--forge-color-accent);
    outline-offset: 2px;
    border-radius: 2px;
  }

  @media (max-width: 600px) {
    /* Scoped to html.js: only hide nav links and show hamburger when JS is available */
    html.js .nav-links {
      display: none;
    }

    html.js .nav-toggle {
      display: flex;
    }

    .footer-inner {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
