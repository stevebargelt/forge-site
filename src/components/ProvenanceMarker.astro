---
interface Props {
  generatedFrom: string;
  linkHref?: string;
}

const { generatedFrom, linkHref } = Astro.props;
---

<div class="provenance-marker" role="note" aria-label={`Data verified against ${generatedFrom}`}>
  <svg aria-hidden="true" class="provenance-icon" width="13" height="13" viewBox="0 0 13 13" fill="none">
    <path d="M6.5 1L12 4v5L6.5 12 1 9V4z" stroke="currentColor" stroke-width="1.25" stroke-linejoin="round"/>
    <path d="M4 6.5l1.5 1.5L9 5" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"/>
  </svg>
  <span class="provenance-text">
    Verified against{' '}
    {linkHref ? (
      <a href={linkHref} class="provenance-link" target="_blank" rel="noopener noreferrer">
        {generatedFrom}
      </a>
    ) : (
      <code class="provenance-code">{generatedFrom}</code>
    )}
  </span>
</div>

<style>
  .provenance-marker {
    display: inline-flex;
    align-items: center;
    gap: var(--forge-space-2);
    padding: var(--forge-space-1) var(--forge-space-3);
    background: color-mix(in srgb, var(--forge-color-accent) 8%, var(--forge-color-surface-raised));
    border: 1px solid color-mix(in srgb, var(--forge-color-accent) 25%, var(--forge-color-border));
    border-radius: var(--forge-radius-md);
    font-family: var(--forge-font-family-mono);
    font-size: var(--forge-font-size-xs);
    color: var(--forge-color-accent-text);
  }

  .provenance-icon {
    flex-shrink: 0;
    color: var(--forge-color-accent);
  }

  .provenance-text {
    white-space: nowrap;
  }

  .provenance-link {
    color: var(--forge-color-accent);
    text-decoration: underline;
    text-decoration-color: color-mix(in srgb, var(--forge-color-accent) 40%, transparent);
    text-underline-offset: 2px;
    transition: text-decoration-color 0.15s ease;
  }

  .provenance-link:hover {
    text-decoration-color: var(--forge-color-accent);
  }

  .provenance-link:focus-visible {
    outline: 2px solid var(--forge-color-accent);
    outline-offset: 2px;
    border-radius: 2px;
  }

  .provenance-code {
    font-family: inherit;
    font-size: inherit;
  }
</style>
